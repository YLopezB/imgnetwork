<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="card-title">{{image.title}}</h2>
    <button
      class="btn btn-danger"
      id="delete-image"
      data-image-id="{{image._id}}"
    >
      <i class="fas fa-trash-alt"></i>
      Borrar
    </button>
  </div>
  <div class="card-body">
    <img
      src="/uploads/{{image.filename}}"
      alt="{{image.title}}"
      class="img-fluid mb-3"
    />
    <p>{{image.description}}</p>
  </div>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <button class="btn btn-success" id="btn-like" data-image-id="{{image._id}}">
      <i class="fas fa-thumbs-up"></i>
      Me gusta
    </button>
    <p>
      <span class="likes-count">{{image.likes}}</span>
      <i class="fas fa-heart"></i>
    </p>
    <p>
      <i class="fas fa-eye"> {{image.views}}</i>
    </p>
    <p>
      <i class="fas fa-clock"> {{timeAgo image.timestamp}}</i>
    </p>
  </div>
</div>

<div class="card mt-2">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3>Comentarios</h3>
    <button class="btn btn-info" id="btn-toggle-comment">
      <i class="fas fa-comment-o"></i>
      Comentar
    </button>
  </div>
  <div class="card-body">
    <blockquote>
      <form action="/images/{{image._id}}/comment" method="POST">
        <div class="form-group mb-2">
          <input
            type="text"
            class="form-control"
            name="name"
            placeholder="Tu nombre"
            required
          />
        </div>
        <div class="form-group mb-2">
          <input
            type="text"
            class="form-control"
            name="email"
            placeholder="Tu email"
            required
          />
        </div>
        <div class="form-group mb-2">
          <textarea
            class="form-control"
            name="comment"
            placeholder="Tu comentario"
            rows="3"
            required
          ></textarea>
        </div>
        <div class="form-group mb-0">
          <button type="submit" class="btn btn-info">
            <i class="fas fa-comment"></i>
            Comentar
          </button>
        </div>
      </form>
    </blockquote>
  </div>

</div>