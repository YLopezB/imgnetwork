<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="card-title">{{image.title}}</h2>
    <button
      class="btn btn-danger"
      id="delete-image"
      data-image-id="{{image._id}}"
    >
      <i class="fas fa-trash-alt"></i>
      Borrar
    </button>
  </div>
  <div class="card-body">
    <img
      src="/uploads/{{image.filename}}"
      alt="{{image.title}}"
      class="img-fluid mb-3"
    />
    <p>{{image.description}}</p>
  </div>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <button class="btn btn-success" id="btn-like" data-image-id="{{image._id}}">
      <i class="fas fa-thumbs-up"></i>
      Me gusta
    </button>
    <p>
      <span class="likes-count">{{image.likes}}</span>
      <i class="fas fa-heart"></i>
    </p>
    <p>
      <i class="fas fa-eye"> {{image.views}}</i>
    </p>
    <p>
      <i class="fas fa-clock"> {{timeAgo image.timestamp}}</i>
    </p>
  </div>
</div>